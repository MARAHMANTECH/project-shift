# ============================================================
# Project SHIFT - Environment Variables
# Kopiér denne fil til .env og udfyld vaerdierne
# ============================================================

# Database (PostgreSQL + PostGIS)
DATABASE_URL="postgresql://shift_user:shift_password@localhost:5432/project_shift?schema=public"

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXTAUTH_URL="http://localhost:3000"

# NestJS
API_PORT=4000
NODE_ENV="development"

# ESG Configuration
ESG_EMISSION_FACTOR_KG_PER_KM=0.12
ESG_FORMULA_VERSION="v1.0"

# Integration Hub
INTEGRATION_WEBHOOK_SECRET=

# Stripe (Etape 4 - deaktiveret i MVP)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
