// prisma/schema.prisma
// Project SHIFT - Corporate Mobility & Community Platform
// Version: v0.1.0 (M1: Fundament & Org-Isolation)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ============================================================
// DOMAIN 1: AUTH & ORGANIZATION
// ============================================================

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logoUrl   String?   @map("logo_url")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  users          User[]
  emailDomains   EmailDomain[]
  meetingPoints  MeetingPoint[]
  rides          Ride[]
  events         Event[]
  partnerLinks   PartnerLink[]
  auditLogs      AuditLog[]
  modules        OrgModule[]
  ssoConnections SsoConnection[]
  integrations   IntegrationConfiguration[]
  license        OrganizationLicense?
  feedbacks      Feedback[]

  @@map("organizations")
}

model EmailDomain {
  id             String   @id @default(cuid())
  domain         String   @unique
  organizationId String   @map("organization_id")
  isVerified     Boolean  @default(false) @map("is_verified")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("email_domains")
}

/// Feature flags per organization - controls which modules are active
model OrgModule {
  id             String     @id @default(cuid())
  organizationId String     @map("organization_id")
  module         ModuleType
  isEnabled      Boolean    @default(true) @map("is_enabled")
  config         Json?
  createdAt      DateTime   @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, module])
  @@index([organizationId])
  @@map("org_modules")
}

enum ModuleType {
  RIDESHARING
  ESG_DASHBOARD
  COMMUNITY
  PAYMENTS
  CANTEEN
  DELIVERY
  SPORT
}

model User {
  id             String    @id @default(cuid())
  externalAuthId String    @unique @map("external_auth_id")
  email          String    @unique
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  avatarUrl      String?   @map("avatar_url")
  role           UserRole  @default(MEMBER)
  organizationId String    @map("organization_id")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization     Organization    @relation(fields: [organizationId], references: [id])
  ridesAsDriver    Ride[]          @relation("DriverRides")
  ridesAsPassenger RidePassenger[]
  eventAttendees   EventAttendee[]
  auditLogs        AuditLog[]
  feedbacks        Feedback[]

  @@index([organizationId])
  @@index([email])
  @@index([externalAuthId])
  @@map("users")
}

enum UserRole {
  MEMBER
  ORG_ADMIN
  SUPER_ADMIN
}

// ============================================================
// DOMAIN 2: RIDESHARING
// ============================================================

/// Public pickup/dropoff locations - NEVER private addresses (Privacy-by-Design)
model MeetingPoint {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  name           String
  address        String
  pointType      PointType @map("point_type")
  latitude       Float
  longitude      Float
  // PostGIS geography column added via raw SQL migration
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  ridesFrom    Ride[]       @relation("DeparturePoint")
  ridesTo      Ride[]       @relation("ArrivalPoint")

  @@index([organizationId])
  @@map("meeting_points")
}

enum PointType {
  TRAIN_STATION
  BUS_STOP
  PARKING_LOT
  COMPANY_HUB
  OTHER
}

model Ride {
  id               String     @id @default(cuid())
  organizationId   String     @map("organization_id")
  driverId         String     @map("driver_id")
  departurePointId String     @map("departure_point_id")
  arrivalPointId   String     @map("arrival_point_id")
  departureTime    DateTime   @map("departure_time")
  availableSeats   Int        @map("available_seats")
  status           RideStatus @default(SCHEDULED)
  distanceKm       Float?     @map("distance_km")
  notes            String?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id])
  driver         User            @relation("DriverRides", fields: [driverId], references: [id])
  departurePoint MeetingPoint    @relation("DeparturePoint", fields: [departurePointId], references: [id])
  arrivalPoint   MeetingPoint    @relation("ArrivalPoint", fields: [arrivalPointId], references: [id])
  passengers     RidePassenger[]
  esgTripLogs    EsgTripLog[]

  @@index([organizationId])
  @@index([departureTime])
  @@index([organizationId, departureTime])
  @@index([driverId])
  @@map("rides")
}

enum RideStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model RidePassenger {
  id       String          @id @default(cuid())
  rideId   String          @map("ride_id")
  userId   String          @map("user_id")
  status   PassengerStatus @default(PENDING)
  bookedAt DateTime        @default(now()) @map("booked_at")

  ride Ride @relation(fields: [rideId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([rideId, userId])
  @@index([userId])
  @@map("ride_passengers")
}

enum PassengerStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ============================================================
// DOMAIN 3: ESG ENGINE
// ============================================================

/// Immutable log - NEVER editable after creation
model EsgTripLog {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  rideId         String   @map("ride_id")
  distanceKm     Float    @map("distance_km")
  passengerCount Int      @map("passenger_count")
  co2SavedKg     Float    @map("co2_saved_kg")
  emissionFactor Float    @map("emission_factor")
  calculatedAt   DateTime @default(now()) @map("calculated_at")
  formulaVersion String   @default("v1.0") @map("formula_version")

  ride Ride @relation(fields: [rideId], references: [id])

  @@index([organizationId])
  @@index([organizationId, calculatedAt])
  @@map("esg_trip_logs")
}

// ============================================================
// DOMAIN 4: COMMUNITY & EVENTS
// ============================================================

model Event {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  title          String
  description    String?
  eventType      EventType @map("event_type")
  startTime      DateTime  @map("start_time")
  endTime        DateTime  @map("end_time")
  location       String?
  maxAttendees   Int?      @map("max_attendees")
  isPublic       Boolean   @default(false) @map("is_public")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id])
  attendees    EventAttendee[]

  @@index([organizationId])
  @@index([organizationId, startTime])
  @@map("events")
}

enum EventType {
  SOCIAL
  SPORTS
  WORKSHOP
  NETWORKING
  OTHER
}

model EventAttendee {
  id           String         @id @default(cuid())
  eventId      String         @map("event_id")
  userId       String         @map("user_id")
  status       AttendeeStatus @default(REGISTERED)
  registeredAt DateTime       @default(now()) @map("registered_at")

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_attendees")
}

enum AttendeeStatus {
  REGISTERED
  WAITLISTED
  CANCELLED
  ATTENDED
}

// ============================================================
// DOMAIN 5: AFFILIATE / PARTNER TRACKING
// ============================================================

model PartnerLink {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  partnerName    String   @map("partner_name")
  targetUrl      String   @map("target_url")
  trackingCode   String   @unique @map("tracking_code")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization   @relation(fields: [organizationId], references: [id])
  clicks       PartnerClick[]

  @@index([organizationId])
  @@index([trackingCode])
  @@map("partner_links")
}

model PartnerClick {
  id            String    @id @default(cuid())
  partnerLinkId String    @map("partner_link_id")
  userId        String?   @map("user_id")
  clickedAt     DateTime  @default(now()) @map("clicked_at")
  convertedAt   DateTime? @map("converted_at")

  partnerLink PartnerLink @relation(fields: [partnerLinkId], references: [id])

  @@index([partnerLinkId])
  @@index([clickedAt])
  @@map("partner_clicks")
}

// ============================================================
// SYSTEM: AUDIT LOG
// ============================================================

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  action         String
  entity         String
  entityId       String   @map("entity_id")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ============================================================
// SYSTEM: IMPERSONATION LOG
// ============================================================

model ImpersonationLog {
  id           String    @id @default(cuid())
  adminUserId  String    @map("admin_user_id")
  targetUserId String    @map("target_user_id")
  startedAt    DateTime  @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")
  reason       String?

  @@index([adminUserId])
  @@index([targetUserId])
  @@map("impersonation_logs")
}

// ============================================================
// DOMAIN 6: ENTERPRISE IDENTITY
// ============================================================

/// SSO connection configuration per organization
model SsoConnection {
  id                 String              @id @default(cuid())
  organizationId     String              @map("organization_id")
  provider           SsoProvider
  /// Clerk Enterprise Connection ID
  clerkConnectionId  String?             @unique @map("clerk_connection_id")
  /// Azure Application ID or Google Client ID
  externalProviderId String?             @map("external_provider_id")
  /// Verified email domains for this SSO connection
  domains            String[]
  status             SsoConnectionStatus @default(PENDING)
  metadata           Json?
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("sso_connections")
}

enum SsoProvider {
  ENTRA_ID
  GOOGLE_WORKSPACE
  CUSTOM_SAML
  CUSTOM_OIDC
}

enum SsoConnectionStatus {
  PENDING
  ACTIVE
  DISABLED
  ERROR
}

// ============================================================
// DOMAIN 7: INTEGRATION HUB
// ============================================================

/// External service integration configuration per organization
model IntegrationConfiguration {
  id              String            @id @default(cuid())
  organizationId  String            @map("organization_id")
  integrationType IntegrationType   @map("integration_type")
  /// Provider-specific settings (API keys, webhook URLs, etc.)
  config          Json              @default("{}")
  status          IntegrationStatus @default(INACTIVE)
  lastSyncAt      DateTime?         @map("last_sync_at")
  errorMessage    String?           @map("error_message")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, integrationType])
  @@index([organizationId])
  @@map("integration_configurations")
}

enum IntegrationType {
  CANTEEN_MENU_SYNC
  DELIVERY_WOLT
  SPORT_WANNASPORT
  CUSTOM_WEBHOOK
}

enum IntegrationStatus {
  INACTIVE
  ACTIVE
  ERROR
  SYNCING
}

/// Webhook event log for integrations
model WebhookEventLog {
  id              String          @id @default(cuid())
  organizationId  String          @map("organization_id")
  integrationType IntegrationType @map("integration_type")
  eventType       String          @map("event_type")
  payload         Json
  status          String          @default("received")
  processedAt     DateTime?       @map("processed_at")
  errorMessage    String?         @map("error_message")
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([organizationId])
  @@index([organizationId, integrationType])
  @@index([createdAt])
  @@map("webhook_event_logs")
}

// ============================================================
// DOMAIN 8: LICENSING & TENANT MANAGEMENT
// ============================================================

/// License/subscription tier per organization (managed by Super Admin)
model OrganizationLicense {
  id             String      @id @default(cuid())
  organizationId String      @unique @map("organization_id")
  tier           LicenseTier @default(TRIAL)
  maxUsers       Int         @default(50) @map("max_users")
  expiresAt      DateTime?   @map("expires_at")
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("organization_licenses")
}

enum LicenseTier {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ============================================================
// DOMAIN 9: CHANGELOG & FEEDBACK
// ============================================================

/// Platform version history — offentlig for alle brugere
model Changelog {
  id             String        @id @default(cuid())
  organizationId String?       @map("organization_id")
  versionBuild   Int           @map("version_build")
  type           ChangelogType
  title          String
  description    String        @db.Text
  isPublished    Boolean       @default(false) @map("is_published")
  publishedAt    DateTime?     @map("published_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([versionBuild])
  @@index([type])
  @@index([publishedAt])
  @@map("changelogs")
}

enum ChangelogType {
  FEATURE
  FIX
  IMPROVEMENT
}

/// Bruger-feedback og feature requests — tenant-scoped
model Feedback {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  userId         String           @map("user_id")
  type           FeedbackType
  status         FeedbackStatus   @default(NEW)
  priority       FeedbackPriority @default(MEDIUM)
  title          String
  content        String           @db.Text
  isGlobal       Boolean          @default(false) @map("is_global")
  resolvedAt     DateTime?        @map("resolved_at")
  changelogId    String?          @map("changelog_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([userId])
  @@index([status])
  @@map("feedback")
}

enum FeedbackType {
  BUG
  FEATURE
  IMPROVEMENT
}

enum FeedbackStatus {
  NEW
  UNDER_REVIEW
  PLANNED
  IN_BUILD
  DONE
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
}
